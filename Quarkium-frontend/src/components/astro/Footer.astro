---
// src/components/astro/Footer.astro
---
<footer class="bg-surface-container-lowest border-t border-outline-variant/10 pt-24 pb-12 z-20 mt-auto relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-20">
      
      <div class="col-span-1 md:col-span-1">
        <div class="font-serif italic text-2xl text-primary mb-8">Quarkium</div>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-8">
          La intersección entre la artesanía tradicional y la estética moderna. Proveedores de cuidado personal de excelencia.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high text-on-surface hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">public</span>
          </a>
          <a href="#" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high text-on-surface hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">share</span>
          </a>
        </div>
      </div>

      <div class="col-span-1">
        <h4 class="font-label text-xs font-bold uppercase tracking-widest text-on-surface mb-8">Horario </h4>
        <ul class="space-y-4 text-sm text-on-surface-variant">
          <li class="flex justify-between"><span>Lun — Vie</span> <span class="text-on-surface">10:00 - 20:00</span></li>
          <li class="flex justify-between"><span>Sábado</span> <span class="text-on-surface">09:00 - 18:00</span></li>
          <li class="flex justify-between"><span>Domingo</span> <span class="text-on-surface">Cerrado</span></li>
        </ul>
      </div>

      <div class="col-span-1">
        <h4 class="font-label text-xs font-bold uppercase tracking-widest text-on-surface mb-8">Ubicación</h4>
        <p class="text-sm text-on-surface-variant leading-relaxed mb-4">
          Calle de los Artesanos, 12<br/>
          28004 Madrid, España
        </p>
        <a href="#" class="text-primary text-xs font-bold uppercase tracking-widest flex items-center gap-2 hover:underline underline-offset-4">
          Cómo Llegar <span class="material-symbols-outlined text-sm">north_east</span>
        </a>
      </div>

      <div class="col-span-1">
        <h4 class="font-label text-xs font-bold uppercase tracking-widest text-on-surface mb-8">Mantente Impecable</h4>
        <form class="space-y-4">
          <input type="email" placeholder="Correo Electrónico" class="w-full bg-surface-container-low border-b-2 border-outline-variant/30 focus:border-primary border-t-0 border-x-0 text-sm py-3 outline-none transition-colors focus:ring-0 text-on-surface placeholder:text-outline/40" />
          <button type="button" class="w-full font-label text-xs font-bold uppercase tracking-widest py-3 text-primary text-left hover:text-primary-container transition-colors">
            Únete a la Sociedad
          </button>
        </form>
      </div>

    </div>

    <div class="border-t border-outline-variant/10 pt-12 flex flex-col md:flex-row justify-between items-center text-xs text-on-surface-variant uppercase tracking-widest">
      <p>© {new Date().getFullYear()} Quarkium. Todos los derechos reservados.</p>
      <div class="flex space-x-8 mt-4 md:mt-0">
        <a href="#" class="hover:text-on-surface transition-colors">Privacidad</a>
        <a href="#" class="hover:text-on-surface transition-colors">Términos</a>
        <a href="#" class="hover:text-on-surface transition-colors">Accesibilidad</a>
      </div>
    </div>
  </div>
</footer>