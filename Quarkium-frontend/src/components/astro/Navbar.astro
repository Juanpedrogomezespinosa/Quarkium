---
// src/components/astro/Navbar.astro
---
<header class="w-full border-b border-outline-variant/20 bg-surface-container-lowest/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="font-headline italic text-2xl text-primary tracking-tight">Quarkium</span>
    </a>

    <nav class="hidden md:flex items-center space-x-8 font-serif text-lg tracking-tight">
      <a href="#servicios" class="text-primary border-b-2 border-primary pb-1 transition-colors duration-300">Servicios</a>
      <a href="#barberos" class="text-on-surface-variant hover:text-primary transition-colors duration-300">Barberos</a>
      <a href="#galeria" class="text-on-surface-variant hover:text-primary transition-colors duration-300">Galería</a>
      <a href="/login" class="text-on-surface-variant hover:text-primary transition-colors duration-300">Portal del Cliente</a>
    </nav>

    <div class="flex items-center space-x-6">
       <a href="/admin" class="hidden lg:block font-label text-[10px] uppercase tracking-[0.2em] text-outline hover:text-primary transition-colors">
         Acceso Staff
       </a>
       <a href="/book" class="gold-shimmer text-on-primary-fixed font-label font-medium uppercase tracking-wider px-6 py-2 rounded-sm hover:shadow-[0_0_20px_rgba(233,195,73,0.4)] hover:scale-105 active:scale-95 transition-all">
         Reservar Cita
       </a>
    </div>
  </div>
</header>